# Copy to backend/.env for local runs outside Docker.
# Prefer project root .env with DEFAULT_LOCALE (see ../.env.example).
APP_ENV=development
SECRET_KEY=dev-local-secret-key-min-32-chars!!
DATABASE_URL=sqlite:///data/app.db
CORS_ORIGINS=http://localhost:5173,http://frontend:5173
DEFAULT_LOCALE=ko
