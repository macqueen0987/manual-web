{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "python hooks/agent_gate_hook.py session",
        "timeout": 15
      }
    ],
    "preToolUse": [
      {
        "command": "python hooks/agent_gate_hook.py pre_edit",
        "matcher": "Write|StrReplace",
        "timeout": 12
      }
    ],
    "beforeShellExecution": [
      {
        "command": "python hooks/agent_gate_hook.py pre_build",
        "matcher": "pytest|npm |pnpm |yarn |make |mvn|gradle|docker ",
        "timeout": 12
      }
    ],
    "stop": [
      {
        "command": "python hooks/agent_gate_hook.py stop",
        "timeout": 15
      }
    ],
    "sessionEnd": [
      {
        "command": "python hooks/agent_gate_hook.py stop",
        "timeout": 15
      }
    ]
  }
}
