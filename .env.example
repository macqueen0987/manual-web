# Manual Web — repo root .env for Docker Compose
# Compose substitutes ${VAR} here; services with env_file: .env pass values into containers.
#
# Dev:  docker compose -f docker-compose.dev.yml up -d
#       → http://localhost:5173  API http://localhost:8000
# Prod: docker compose -f docker-compose.prod.yml up --build -d
#       → http://localhost:${FRONTEND_PORT}  (API via nginx /api/)
# MCP:  add --profile mcp up -d mcp  (either compose file)

# --- Shared (dev + prod backend / frontend) ---
# Prod frontend: baked into static build via docker-compose.prod.yml build arg.
DEFAULT_LOCALE=ko

# Site header branding (backend serves /api/site/branding; logo via /uploads when local file)
# SITE_BRAND_TITLE=My Documentation
# SITE_BRAND_LOGO_LETTER=M
# Local image: absolute path inside backend container, or https:// URL
# SITE_BRAND_LOGO_PATH=/app/data/branding/logo.png
# Dev example: mount ./branding → backend data/branding and set SITE_BRAND_LOGO_PATH=/app/data/branding/logo.png

# Home page hero band — UTF-8 HTML file (full <section>… markup). Sanitized on serve.
# See branding/home-hero.ko.example.html. Locale-specific paths override SITE_HOME_HERO_HTML_PATH.
# SITE_HOME_HERO_HTML_PATH=/app/data/branding/home-hero.html
# SITE_HOME_HERO_HTML_PATH_KO=/app/data/branding/home-hero.ko.html
# SITE_HOME_HERO_HTML_PATH_EN=/app/data/branding/home-hero.en.html

# Public page footer — UTF-8 HTML (<footer>…). Sanitized on serve. See branding/site-footer.ko.example.html
# SITE_FOOTER_HTML_PATH=/app/data/branding/site-footer.html
# SITE_FOOTER_HTML_PATH_KO=/app/data/branding/site-footer.ko.html
# SITE_FOOTER_HTML_PATH_EN=/app/data/branding/site-footer.en.html

# JWT signing (32+ characters). Dev default is fine locally; change for real LAN deploy.
SECRET_KEY=dev-local-secret-key-min-32-chars!!

# Comma-separated browser origins for CORS (include every URL users open in the browser).
# Dev Vite + prod nginx on default ports:
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost,http://127.0.0.1,http://localhost:80

# SQLite path inside backend container (data dir is mounted at ./backend/data)
DATABASE_URL=sqlite:///data/app.db

# --- Prod host ports (ignored by docker-compose.dev.yml) ---
FRONTEND_PORT=80
BACKEND_PORT=8000

# --- MCP optional profile (dev or prod compose) ---
MCP_PORT=8001
# MCP container: SQLite path inside container (compose mounts ./backend/data → /mcp-data)
# MCP_DATABASE_PATH=/mcp-data/app.db
MCP_ADMIN_EMAIL=mcp-admin@example.com
MCP_ADMIN_PASSWORD=mcp-dev-password-min-16-chars
MCP_ADMIN_NAME=MCP Admin
MCP_BOOTSTRAP_PRODUCT_NAME=MCP Workspace
MCP_BOOTSTRAP_PRODUCT_SLUG=mcp-workspace
