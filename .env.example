# Default locale for UI, editor, and doc folders (en | ko).
DEFAULT_LOCALE=ko

# --- LAN production (docker-compose.prod.yml) ---
# Required when using prod overlay (32+ characters).
SECRET_KEY=change-me-to-a-random-string-at-least-32-chars

# Browser origin(s) allowed by the API (comma-separated).
# Example for LAN host serving frontend on port 80:
# CORS_ORIGINS=http://192.168.1.50,http://192.168.1.50:80
CORS_ORIGINS=http://localhost,http://127.0.0.1

# Host port for nginx frontend in prod overlay (default 80).
FRONTEND_PORT=80
