# Manual Web — repo root .env for Docker Compose
# Compose substitutes ${VAR} here; services with env_file: .env pass values into containers.
#
# Dev:  docker compose -f docker-compose.dev.yml up -d
#       → http://localhost:5173  API http://localhost:8000
# Prod: docker compose -f docker-compose.prod.yml up --build -d
#       → http://localhost:${FRONTEND_PORT}  (API via nginx /api/)
# MCP:  add --profile mcp up -d mcp  (either compose file)

# --- Shared (dev + prod backend / frontend) ---
DEFAULT_LOCALE=ko

# JWT signing (32+ characters). Dev default is fine locally; change for real LAN deploy.
SECRET_KEY=dev-local-secret-key-min-32-chars!!

# Comma-separated browser origins for CORS (include every URL users open in the browser).
# Dev Vite + prod nginx on default ports:
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost,http://127.0.0.1,http://localhost:80

# SQLite path inside backend container (data dir is mounted at ./backend/data)
DATABASE_URL=sqlite:///data/app.db

# --- Prod host ports (ignored by docker-compose.dev.yml) ---
FRONTEND_PORT=80
BACKEND_PORT=8000

# --- MCP optional profile (dev or prod compose) ---
MCP_PORT=8001
MCP_ADMIN_EMAIL=mcp-admin@manual.local
MCP_ADMIN_PASSWORD=mcp-dev-password-min-16-chars
MCP_ADMIN_NAME=MCP Admin
MCP_BOOTSTRAP_PRODUCT_NAME=MCP Workspace
MCP_BOOTSTRAP_PRODUCT_SLUG=mcp-workspace
